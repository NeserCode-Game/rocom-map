# 洛克王国世界地图 - 环境配置
# Vite 自动加载 .env 文件，变量需以 VITE_ 开头才能在客户端使用

# API 配置
VITE_API_BASE=https://terra-api.17173.com
VITE_API_MAP_ID=4010

# 瓦片资源配置
VITE_TILE_BASE=https://ue.17173cdn.com/a/terra/tiles/rocom
VITE_TILE_VERSION=4010_v3_7f2d9c

# 图标资源配置
VITE_ICON_BASE=https://ue.17173cdn.com/a/terra/icon/rocom

# 请求头伪装
VITE_REQUEST_ORIGIN=https://map.17173.com
VITE_REQUEST_REFERER=https://map.17173.com/

# 缓存配置
VITE_CACHE_TILES_TTL_MS=7200000
VITE_CACHE_ASSETS_TTL_MS=86400000
